{
  "database_name": "NetworkingAssistantDB",
  "entities": [
    {
      "table_name": "User",
      "description": "Stores user profile and professional interests",
      "attributes": [
        { "name": "user_id", "type": "INT", "primary_key": true },
        { "name": "name", "type": "VARCHAR(255)", "primary_key": false },
        { "name": "interests", "type": "TEXT", "primary_key": false, "note": "Stored as JSON string" }
      ]
    },
    {
      "table_name": "Event",
      "description": "Stores details about the networking events",
      "attributes": [
        { "name": "event_id", "type": "INT", "primary_key": true },
        { "name": "event_name", "type": "VARCHAR(255)", "primary_key": false },
        { "name": "category", "type": "VARCHAR(100)", "primary_key": false, "note": "Classified automatically by DistilBERT model" },
        { "name": "themes", "type": "TEXT", "primary_key": false, "note": "Stored as JSON string" }
      ]
    },
    {
      "table_name": "GeneratedTopics",
      "description": "Stores the icebreakers and conversation starters generated by GPT-2",
      "attributes": [
        { "name": "topic_id", "type": "INT", "primary_key": true },
        { "name": "event_id", "type": "INT", "primary_key": false, "foreign_key": "Event.event_id" },
        { "name": "user_id", "type": "INT", "primary_key": false, "foreign_key": "User.user_id" },
        { "name": "suggestion_text", "type": "TEXT", "primary_key": false }
      ]
    }
  ],
  "relationships": [
    {
      "name": "User_attends_Event",
      "type": "Many-to-Many",
      "entities": ["User", "Event"],
      "description": "Users can attend multiple events, and events have multiple users attending them."
    },
    {
      "name": "Event_has_Topics",
      "type": "One-to-Many",
      "from": "Event",
      "to": "GeneratedTopics",
      "description": "One event can have multiple generated conversation topics linked to it."
    }
  ]
}